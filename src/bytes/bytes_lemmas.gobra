func lemmaSepNotEquals(s, sep seq[byte], a, b int) {
	if b < 0 {
		return
	}
	invariant InRangeInc(k, a, a+b+1)
	invariant forall i0 int :: { s[i0:i0+len(sep)] } InRange(i0, a, k) ==>
		s[i0:i0+len(sep)] != sep
	decreases a+b+1-k
	for k := a; k < a+b+1; k++ {
		assert s[k:k+len(sep)] == s[a:][k-a:k-a+len(sep)]
	}

}

