func lemmaViewSliceSepEquals(s []byte, sep seq[byte], i, r int) {
	invariant InRangeInc(k, 0, r)
	invariant acc(sl.Bytes(s, 0, len(s)), R50)
	invariant acc(sl.Bytes(s[i:], 0, len(s[i:])), R50)
	invariant forall j int :: {sl.View(s[i:])[j:j+len(sep)]}{s[j]} 0 <= j && j < r ==> sl.View(s[i:])[j:j+len(sep)] != sep
	invariant forall j int :: {sl.View(s)[i:][j:j+len(sep)]} 0 <= j && j < k ==> sl.View(s)[i:][j:j+len(sep)] != sep
	decreases r-k
	for k := 0; k < r; k++ {
		unfold acc(sl.Bytes(s[i:], 0, len(s[i:])), R50/2)
		unfold acc(sl.Bytes(s, 0, len(s)), R50/2)
		SubSliceOverlaps(s, i, len(s))
		assert sl.View(s)[i:][k] == sl.View(s[i:])[k]
		assert sl.View(s)[i:][k:k+len(sep)] == sl.View(s[i:])[k:k+len(sep)]
		assert sl.View(s[i:])[k:k+len(sep)] != sep
		assert sl.View(s)[i:][k:k+len(sep)] != sep
		fold acc(sl.Bytes(s, 0, len(s)), R50/2)
		fold acc(sl.Bytes(s[i:], 0, len(s[i:])), R50/2)
	}
}


