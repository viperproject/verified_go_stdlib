func lemmaStillHaveToRepeat(i, count, bp, lb, lnb int) {
	if lb != 0 {
		assert lb * i < lnb
		assert lb * i < lb * count
		LemmaMulInjLtLeftInv(i, count, lb)
		assert i < count
