requires InRangeInc(i, 0, len(s))
requires acc(sl.Bytes(s[i:], 0, len(s[i:])), R50)
requires forall k int :: {sl.View(s[i:])[k:k+len(sep)]} InRangeInc(k, 0, len(s[i:])-len(sep)) ==> sl.View(s[i:])[k:k+len(sep)] != sep
ensures acc(sl.Bytes(s[i:], 0, len(s[i:])), R50)
ensures InRangeInc(j, 0, len(s[i:])-len(sep)) ==> sl.View(s[i:])[j:j+len(sep)] != sep
decreases
func lemmaManuallyTriggerForall(s []byte, sep seq[byte], i, j int) { }

ghost
requires InRangeInc(i, 0, len(s))
requires acc(sl.Bytes(s, 0, len(s)), R49)
requires acc(sl.Bytes(s[i:], 0, len(s[i:])), R49)
requires forall k int :: {sl.View(s[i:])[k:k+len(sep)]} InRangeInc(k, 0, len(s[i:])-len(sep)) ==> sl.View(s[i:])[k:k+len(sep)] != sep
ensures acc(sl.Bytes(s, 0, len(s)), R49)
ensures acc(sl.Bytes(s[i:], 0, len(s[i:])), R49)
ensures forall k int :: {sl.View(s)[i:][k:k+len(sep)]} InRangeInc(k, 0, len(s[i:])-len(sep)) ==> sl.View(s)[i:][k:k+len(sep)] != sep
decreases
func lemmaViewEqualsIndex(s []byte, sep seq[byte], i int) {
	assert forall k int :: {sl.View(s[i:])[k:k+len(sep)]} InRangeInc(k, 0, len(s[i:])-len(sep)) ==> sl.View(s[i:])[k:k+len(sep)] != sep
	if len(s[i:]) < len(sep) {
		return
	}
	lemmaViewSubslice(s, i, len(s))
	lemmaManuallyTriggerForall(s, sep, i, 0)

	invariant InRangeInc(j, 0, len(s[i:])-len(sep))
	invariant acc(sl.Bytes(s, 0, len(s)), R49)
	invariant acc(sl.Bytes(s[i:], 0, len(s[i:])), R49)
	invariant forall k int :: {sl.View(s[i:])[k:k+len(sep)]} InRangeInc(k, 0, len(s[i:])-len(sep)) ==> sl.View(s[i:])[k:k+len(sep)] != sep
	invariant forall k int :: {sl.View(s)[i:][k:k+len(sep)]} InRangeInc(k, 0, j) ==> sl.View(s)[i:][k:k+len(sep)] != sep
	decreases len(s[i:])-len(sep)-j
	for j := 0; j < len(s[i:])-len(sep); j++ {
		lemmaViewSubslice(s, i, len(s))
		lemmaManuallyTriggerForall(s, sep, i, j+1)
	}
}


ghost
requires forall k int :: { s[k:k+len(sep)] } 0 <= k && k < i ==> s[k:k+len(sep)] != sep
requires s[i:i+len(sep)] != sep
ensures  forall k int :: { s[k:k+len(sep)] } 0 <= k && k < i+1 ==> s[k:k+len(sep)] != sep
decreases
func lemmaIndexStepOne(s, sep seq[byte], i int) { }
