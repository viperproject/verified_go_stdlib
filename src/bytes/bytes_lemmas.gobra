ghost
requires 2 <= len(s)
requires 0 < i
requires forall k int :: {s[k:k+len(sep)]} InRange(k, 0, i) ==> s[k:k+len(sep)] != sep
requires forall k int :: {s[i:][k:k+len(sep)]} InRangeInc(k, 0, len(s[i:])) ==> s[i:][k:k+len(sep)] != sep
ensures  forall k int :: {s[k:k+len(sep)]} 0 <= k && k + len(sep) <= len(s) ==> s[k:k+len(sep)] != sep
decreases
func lemmaIndexNotFound(s, sep seq[byte], i int) {
	invariant InRangeInc(j, 0, i)
	invariant forall k int :: {s[k:k+len(sep)]} InRange(k, 0, j) ==> s[k:k+len(sep)] != sep
	decreases i - j
	for j := 0; j < i; j++ {
		assert InRange(j, 0, i)
		assert s[j:j+len(sep)] != sep
	}


	assert s[i:][0:0+len(sep)] != sep

	if i >= len(s)-len(sep) {
		assert forall k int :: {s[k:k+len(sep)]} InRangeInc(k, 0, len(s)-len(sep)) ==> s[k:k+len(sep)] != sep
		assert forall k int :: {s[k:k+len(sep)]} 0 <= k && k + len(sep) <= len(s) ==> s[k:k+len(sep)] != sep
		return
	}

	assert forall k int :: {s[k:k+len(sep)]} InRangeInc(k, 0, i) ==> s[k:k+len(sep)] != sep

	j := i
	invariant InRangeInc(j, i, len(s)-len(sep)+1)
	invariant forall k int :: {s[k:k+len(sep)]} InRangeInc(k, 0, j) ==> s[k:k+len(sep)] != sep
	decreases len(s) - j
	for ; j < len(s)-len(sep); j++ {
		assert forall k int :: {s[k:k+len(sep)]} InRangeInc(k, 0, j) ==> s[k:k+len(sep)] != sep
		assert s[i:][j-i:j-i+len(sep)] == s[j:j+len(sep)]
		assert s[i:][j+1-i:j+1-i+len(sep)] == s[j+1:j+1+len(sep)]
		assert s[i:][j-i:j-i+len(sep)] != sep
		assert s[j:j+len(sep)] != sep
	}

	assert forall k int :: {s[k:k+len(sep)]} InRangeInc(k, 0, j) ==> s[k:k+len(sep)] != sep
	assert forall k int :: {s[k:k+len(sep)]} InRangeInc(k, 0, len(s)-len(sep)) ==> s[k:k+len(sep)] != sep
}

