ghost
requires InRangeInc(i, 0, len(s))
requires InRangeInc(r, 0, len(s)-i)
requires forall j int :: {s[i:][j:j+len(sep)]}{s[j]} 0 <= j && j < r ==> s[i:][j:j+len(sep)] != sep
ensures  forall j int :: {s[j:j+len(sep)]} i <= j && j < r+i ==> s[j:j+len(sep)] != sep
decreases
func lemmaSliceSequence(s, sep seq[byte], i, r int) {
	invariant forall j int :: {s[j:j+len(sep)]} i <= j && j < k ==> s[j:j+len(sep)] != sep
	invariant InRangeInc(k, i, r+i)
	decreases r+i-k
	for k := i; k < r+i; k++ {
		assert s[k] == s[i:][k-i]
		assert s[k:k+len(sep)] === s[i:][k-i:k-i+len(sep)]
		assert s[k:k+len(sep)] != sep
	}
}


ghost
requires InRangeInc(i, 0, len(s))
requires InRangeInc(r, 0, len(s)-i)
requires acc(sl.Bytes(s, 0, len(s)), R50)
requires acc(sl.Bytes(s[i:], 0, len(s[i:])), R50)
requires forall j int :: {sl.View(s[i:])[j:j+len(sep)]} 0 <= j && j < r ==> sl.View(s[i:])[j:j+len(sep)] != sep
ensures  acc(sl.Bytes(s, 0, len(s)), R50)
ensures  acc(sl.Bytes(s[i:], 0, len(s[i:])), R50)
ensures  forall j int :: {sl.View(s)[i:][j:j+len(sep)]} 0 <= j && j < r ==> sl.View(s)[i:][j:j+len(sep)] != sep
decreases
func lemmaViewSliceSepEquals(s []byte, sep seq[byte], i, r int) {
	invariant InRangeInc(k, 0, r)
	invariant acc(sl.Bytes(s, 0, len(s)), R50)
	invariant acc(sl.Bytes(s[i:], 0, len(s[i:])), R50)
	invariant forall j int :: {sl.View(s[i:])[j:j+len(sep)]}{s[j]} 0 <= j && j < r ==> sl.View(s[i:])[j:j+len(sep)] != sep
	invariant forall j int :: {sl.View(s)[i:][j:j+len(sep)]} 0 <= j && j < k ==> sl.View(s)[i:][j:j+len(sep)] != sep
	decreases r-k
	for k := 0; k < r; k++ {
		unfold acc(sl.Bytes(s[i:], 0, len(s[i:])), R50/2)
		unfold acc(sl.Bytes(s, 0, len(s)), R50/2)
		SubSliceOverlaps(s, i, len(s))
		assert sl.View(s)[i:][k] == sl.View(s[i:])[k]
		assert sl.View(s)[i:][k:k+len(sep)] == sl.View(s[i:])[k:k+len(sep)]
		assert sl.View(s[i:])[k:k+len(sep)] != sep
		assert sl.View(s)[i:][k:k+len(sep)] != sep
		fold acc(sl.Bytes(s, 0, len(s)), R50/2)
		fold acc(sl.Bytes(s[i:], 0, len(s[i:])), R50/2)
	}
}

ghost
requires 2 <= len(s)
requires t == len(s) - len(sep) + 1
requires 0 <= i && i+1 <= t && t <= len(s)
requires i < t
requires 0 <= o && o < t-i-1
requires s[i] != sep[0]
requires forall j int :: { s[j:j+len(sep)] } 0 <= j && j < i ==> s[j:j+len(sep)] != sep
requires forall j int :: {s[i+1:t][j]} 0 <= j && j < o ==> s[i+1:t][j] != sep[0]
ensures  forall j int :: { s[j:j+len(sep)] } 0 <= j && j < i+o+1 ==> s[j:j+len(sep)] != sep
decreases
func lemmaIndexIndexByteIsNotPrefix(s, sep seq[byte], i, t, o int) {
	invariant forall j int :: {s[i+1:t][j]} 0 <= j && j < o ==> s[i+1:t][j] != sep[0]
	invariant i+1 <= idx
	invariant forall j int :: { s[j:j+len(sep)] } 0 <= j && j < idx ==> s[j:j+len(sep)] != sep
	decreases i+o+1-idx
	for idx := i+1; idx < i+o+1 ; idx++ {
		assert s[idx] == s[i+1:t][idx - (i+1)]
		assert s[idx] != sep[0]
		assert s[idx:idx+len(sep)] != sep
	}
}
